# Copy to .env for local eval and recording runs. Never commit the real file.
# Deployed Lambdas do not read any of this. They get config from CDK env + SSM.

# Which ModelProvider the eval harness uses: recorded | bedrock | anthropic
DOCKET_PROVIDER=recorded

# Set to 1 with a live provider to write model responses into eval/fixtures.
DOCKET_RECORD=0

# Only needed for the anthropic fallback provider. In AWS this lives in SSM, not here.
ANTHROPIC_API_KEY=

# Region is pinned to us-east-1 everywhere. Override only if you know why.
AWS_REGION=us-east-1
