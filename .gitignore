# dependencies
node_modules/

# build + cdk output
dist/
*.js
*.d.ts
!eslint.config.mjs
# hand-written type shims under src are source, not compiled output
!src/**/*.d.ts
cdk.out/
*.tsbuildinfo

# test + coverage
coverage/
.vitest/

# eval output is regenerated by `npm run eval`, never committed
eval/results/

# local env + secrets. Nothing long-lived AWS ever lands here.
.env
.env.local
*.pem

# editor / OS
.DS_Store
.idea/
.vscode/
*.log

# cdk context cache can leak account ids
cdk.context.json
