# dependencies
node_modules/

# build + cdk output
dist/
*.js
*.d.ts
!eslint.config.mjs
# hand-written type shims under src are source, not compiled output
!src/**/*.d.ts
cdk.out/
*.tsbuildinfo
# the static demo is a build artifact, regenerated by `npm run demo:static` and
# published by the pages workflow, so it is not committed
demo/static/

# test + coverage
coverage/
.vitest/

# eval run outputs are regenerated by `npm run eval`. The kept prompt comparison
# lives alongside them and is committed.
eval/results/*.json

# local env + secrets. Nothing long-lived AWS ever lands here.
.env
.env.local
*.pem

# editor / OS
.DS_Store
.idea/
.vscode/
*.log

# cdk context cache can leak account ids
cdk.context.json
