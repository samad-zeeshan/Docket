{
  "name": "docket",
  "version": "0.1.0",
  "private": true,
  "description": "Event-driven serverless receipt extraction pipeline on AWS. Schema-gated LLM output, evaluated against a golden set.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "docket": "bin/docket.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy",
    "eval": "tsx eval/run.ts",
    "eval:record": "DOCKET_PROVIDER=bedrock DOCKET_RECORD=1 tsx eval/run.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.16.5",
    "@types/pdf-parse": "^1.1.4",
    "aws-cdk": "^2.160.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.11.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@aws-lambda-powertools/logger": "^2.9.0",
    "@aws-lambda-powertools/metrics": "^2.9.0",
    "@aws-lambda-powertools/tracer": "^2.9.0",
    "@aws-sdk/client-bedrock-runtime": "^3.658.0",
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/client-ssm": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  }
}
